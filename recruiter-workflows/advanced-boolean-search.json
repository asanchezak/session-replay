{
  "name": "Recruiter: Advanced BOOLEAN search → candidates (parameterized)",
  "description": "Parameterized BOOLEAN search via the Recruiter ADVANCED search keyword field. Flow (selectors captured live 2026-06-09): navigate /talent/search/advanced → click 'Add Profile keywords or boolean' (opens the keyword input) → type {{boolean_query}} into input[placeholder^='enter keywords'] (commits on Enter) → click Search (button[data-test-save-advanced-button]) → extract candidates (recruiter_search_people; the daemon also returns total_count + paginates). v1 = boolean only; location + years facets are v2 (typeahead-selects). Param: boolean_query. backend create_run substitutes runtime_params.",
  "target_url": "https://www.linkedin.com/talent/home",
  "steps": [
    {"action_type":"navigate","intent":"Warm: Talent home","value":"https://www.linkedin.com/talent/home"},
    {"action_type":"navigate","intent":"Advanced search","value":"https://www.linkedin.com/talent/search/advanced"},
    {"action_type":"scroll","intent":"load 1"},
    {"action_type":"scroll","intent":"load 2"},
    {"action_type":"click","intent":"Open Profile keywords (boolean) facet","selector_chain":[{"type":"css","value":"button[aria-label='Add Profile keywords or boolean']"},{"type":"accessibility","value":"Add Profile keywords or boolean"}]},
    {"action_type":"scroll","intent":"delay: keyword input renders 1"},
    {"action_type":"scroll","intent":"delay: keyword input renders 2"},
    {"action_type":"type","intent":"Boolean keyword query + commit","value":"{{boolean_query}}\n","selector_chain":[{"type":"css","value":"input[placeholder^='enter keywords']"}]},
    {"action_type":"scroll","intent":"settle after boolean"},
    {"action_type":"click","intent":"Run the advanced search","selector_chain":[{"type":"css","value":"button[data-test-save-advanced-button]"},{"type":"css","value":"button.advanced-search__header--actions-primary"},{"type":"text","value":"Search"}]},
    {"action_type":"scroll","intent":"results load 1"},
    {"action_type":"scroll","intent":"results load 2"},
    {"action_type":"scroll","intent":"results load 3"},
    {"action_type":"extract","intent":"Extract candidates + total count","methods":[{"kind":"extract_strategy","strategy":"recruiter_search_people"}]}
  ]
}
