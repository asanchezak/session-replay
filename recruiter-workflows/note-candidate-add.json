{
  "name": "LinkedIn Recruiter: add note to ONE candidate (push)",
  "description": "Push one Odoo linkedin.candidate.note to LinkedIn — select candidate by name in a project, add note (gated by save). No stage move.",
  "target_url": "https://www.linkedin.com/talent/projects",
  "steps": [
    {
      "action_type": "navigate",
      "intent": "Warm: Talent home",
      "value": "https://www.linkedin.com/talent/home"
    },
    {
      "action_type": "scroll",
      "intent": "settle"
    },
    {
      "action_type": "extract",
      "intent": "Select candidate by name + add their note (gated)",
      "methods": [
        {
          "kind": "extract_strategy",
          "strategy": "recruiter_candidate_note_add"
        },
        {
          "kind": "recruiter_candidate_note_add",
          "project_url": "{{project_url}}",
          "candidate_name": "{{candidate_name}}",
          "note_text": "{{note_text}}",
          "save": "{{save}}"
        }
      ]
    }
  ]
}
