{
  "name": "Recruiter: FOCUSED boolean + location search -> extract 30",
  "description": "Focused Recruiter advanced search plus recruiter_search_people extraction capped at 30 candidates. Use this to verify lazy-load scrolling + pagination from /talent/search without saving anything. Params: boolean_query, location. The boolean facet commits on Enter; the location facet commits by selecting the top typeahead suggestion.",
  "target_url": "https://www.linkedin.com/talent/home",
  "steps": [
    {
      "action_type": "navigate",
      "intent": "Warm: Talent home",
      "value": "https://www.linkedin.com/talent/home"
    },
    {
      "action_type": "navigate",
      "intent": "Advanced search",
      "value": "https://www.linkedin.com/talent/search/advanced"
    },
    {
      "action_type": "scroll",
      "intent": "load 1"
    },
    {
      "action_type": "scroll",
      "intent": "load 2"
    },
    {
      "action_type": "click",
      "intent": "Open keyword/boolean facet",
      "selector_chain": [
        {
          "type": "css",
          "value": "[data-test-facet-keywords] button[data-test-facet-edit]"
        },
        {
          "type": "css",
          "value": "button[aria-label=\"Add Profile keywords or boolean\"]"
        },
        {
          "type": "css",
          "value": "button[aria-label=\"Añadir Palabras clave del perfil u operadores booleanos\"]"
        }
      ],
      "success_condition": {
        "type": "selector_exists",
        "selector": "textarea[data-test-free-text-single-value-facet-textarea]"
      },
      "checkpoint": true
    },
    {
      "action_type": "scroll",
      "intent": "delay keyword textarea 1"
    },
    {
      "action_type": "scroll",
      "intent": "delay keyword textarea 2"
    },
    {
      "action_type": "type",
      "intent": "Boolean keywords + Enter to commit",
      "selector_chain": [
        {
          "type": "css",
          "value": "textarea[data-test-free-text-single-value-facet-textarea]"
        }
      ],
      "value": "{{boolean_query}}\n"
    },
    {
      "action_type": "scroll",
      "intent": "settle keyword commit"
    },
    {
      "action_type": "click",
      "intent": "Open location facet",
      "selector_chain": [
        {
          "type": "css",
          "value": "[data-test-facet-geo-locations] button[data-test-facet-edit]"
        },
        {
          "type": "css",
          "value": "button[aria-label=\"Add a Candidate geographic location\"]"
        },
        {
          "type": "css",
          "value": "button[aria-label=\"Añadir ubicación del candidato\"]"
        }
      ],
      "success_condition": {
        "type": "selector_exists",
        "selector": "[data-test-facet-geo-locations] input.ts-common-typeahead__input"
      },
      "checkpoint": true
    },
    {
      "action_type": "scroll",
      "intent": "delay location input 1"
    },
    {
      "action_type": "scroll",
      "intent": "delay location input 2"
    },
    {
      "action_type": "type",
      "intent": "Type location into typeahead",
      "selector_chain": [
        {
          "type": "css",
          "value": "[data-test-facet-geo-locations] input.ts-common-typeahead__input"
        },
        {
          "type": "css",
          "value": "[data-test-facet-locations] input.ts-common-typeahead__input"
        },
        {
          "type": "css",
          "value": "input[placeholder^=\"Introducir una ubicación\"]"
        }
      ],
      "value": "{{location}}"
    },
    {
      "action_type": "scroll",
      "intent": "delay suggestions dropdown 1"
    },
    {
      "action_type": "scroll",
      "intent": "delay suggestions dropdown 2"
    },
    {
      "action_type": "click",
      "intent": "Select top location suggestion",
      "selector_chain": [
        {
          "type": "css",
          "value": "li[data-live-test-result=\"0\"]"
        },
        {
          "type": "css",
          "value": "[data-test-typeahead-results] li[role=\"option\"]"
        }
      ]
    },
    {
      "action_type": "scroll",
      "intent": "settle location applied 1"
    },
    {
      "action_type": "scroll",
      "intent": "settle location applied 2"
    },
    {
      "action_type": "click",
      "intent": "Run the advanced search",
      "selector_chain": [
        {
          "type": "css",
          "value": "button[data-test-save-advanced-button]"
        },
        {
          "type": "css",
          "value": "button.advanced-search__header--actions-primary"
        }
      ]
    },
    {
      "action_type": "scroll",
      "intent": "results load 1"
    },
    {
      "action_type": "scroll",
      "intent": "results load 2"
    },
    {
      "action_type": "extract",
      "intent": "Extract 30 candidates + total count",
      "methods": [
        {
          "kind": "extract_strategy",
          "strategy": "recruiter_search_people",
          "target_count": 30,
          "max_pages": 4,
          "max_scroll_passes": 18
        }
      ]
    }
  ]
}
