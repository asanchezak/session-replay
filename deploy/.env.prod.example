# Copy to deploy/.env.prod ON THE EC2 HOST (gitignored) and fill in real secrets.
# DOMAIN is the stable HTTPS hostname Caddy gets a cert for (sslip.io maps it to the EIP).
DOMAIN=<elastic-ip-with-dashes>.sslip.io

# Postgres (fresh DB on the box)
POSTGRES_USER=sr
POSTGRES_PASSWORD=<generate-strong>
POSTGRES_DB=workflow

# Backend secrets — DO NOT reuse the repo dev defaults in production
API_KEY=<generate-strong-random>
SECRET_KEY=<generate-strong-random>
AI_API_KEY=<openai-key-from-backend/.env>

# Allowed browser origins for the dashboard (extension is allowed via regex in code).
# If the dashboard runs locally pointed at AWS, include http://localhost:5173.
CORS_ORIGINS=["http://localhost:5173"]
