{
  "manifest_version": 3,
  "name": "Session Replay — Workflow Runtime",
  "version": "0.1.0",
  "description": "Record, replay, and automate browser workflows with human-in-the-loop control",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Session Replay"
  },
  "side_panel": {
    "default_path": "dist/panel.html"
  },
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/index.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
