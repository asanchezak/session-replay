# Local dev defaults. To target the AWS backend, build with:
#   VITE_API_BASE_URL=https://52-5-45-84.sslip.io/v1 VITE_API_KEY=<gateway-key> npm run build
# VITE_API_KEY is baked into the build (chrome.storage.session is volatile across
# Chrome restarts, so the key must be in the bundle for remote hosts).
VITE_API_BASE_URL=http://localhost:8081/v1
VITE_API_KEY=dev-api-key-change-in-production
VITE_DASHBOARD_ORIGIN=http://localhost:5173
